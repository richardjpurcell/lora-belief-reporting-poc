  "schedule_schema": [
    "source_id",
    "source_time",
    "demand_index",
    "region_id",
    "event_type",
    "priority",
    "usefulness",
    "stale_after",
    "policy_name",
    "policy_code",
    "decision",
    "decision_reason"
  ],
  "compact_schema": [
    "seq",
    "region",
    "event",
    "priority",
    "usefulness",
    "stale_after",
    "policy"
