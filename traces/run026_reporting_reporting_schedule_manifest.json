      "threshold": 0.79,
      "schedule_path": "traces/run026_reporting_txb_usefulness_threshold_schedule.csv",
      "compact_trace_path": "traces/run026_reporting_txb_usefulness_threshold_compact.csv",
      "summary": {
        "demand_rows": 16,
        "send_rows": 4,
        "skip_rows": 12,
        "send_fraction": 0.25,
        "scheduled_total_usefulness": 3.46,
        "scheduled_mean_usefulness": 0.865
