{
  "run_id": "R29",
  "milestone": "v3.0-run029-longer-sd-schedule-prep",
  "description": "Run 029 longer two-transmitter reporting schedule preparation. This artifact defines 64-row full schedules and SEND-only compact traces; the SD replay schedules are generated separately from the full schedules.",
  "input": {
    "path": "traces/run029_longer_adapter_input.csv",
    "schema": [
      "source_id",
      "source_time",
      "demand_index",
      "region_id",
      "event_type",
      "priority",
      "usefulness",
      "stale_after",
      "policy_hint",
      "source_policy",
      "source_note"
    ],
    "rows": 64
  },
  "outputs": {
    "txa": {
      "policy": "fixed_all",
      "schedule_path": "traces/run029_reporting_txa_fixed_all_schedule.csv",
      "compact_trace_path": "traces/run029_reporting_txa_fixed_all_compact.csv",
      "summary": {
        "demand_rows": 64,
        "send_rows": 64,
        "skip_rows": 0,
        "send_fraction": 1.0,
        "scheduled_total_usefulness": 33.6,
        "scheduled_mean_usefulness": 0.525
      }
    },
    "txb": {
      "policy": "usefulness_threshold",
      "threshold": 0.5,
      "schedule_path": "traces/run029_reporting_txb_usefulness_threshold_schedule.csv",
      "compact_trace_path": "traces/run029_reporting_txb_usefulness_threshold_compact.csv",
      "summary": {
        "demand_rows": 64,
        "send_rows": 32,
        "skip_rows": 32,
        "send_fraction": 0.5,
        "scheduled_total_usefulness": 25.92,
        "scheduled_mean_usefulness": 0.81
      }
    }
  },
  "schedule_schema": [
    "source_id",
    "source_time",
    "demand_index",
    "region_id",
    "event_type",
    "priority",
    "usefulness",
    "stale_after",
    "policy_name",
    "policy_code",
    "decision",
    "decision_reason"
  ],
  "compact_schema": [
    "seq",
    "region",
    "event",
    "priority",
    "usefulness",
    "stale_after",
    "policy"
  ],
  "cautions": [
    "This is a reporting-schedule design artifact, not a physical LoRa run.",
    "Compact trace outputs contain SEND rows only.",
    "Airtime-saving claims require firmware scheduling/skipping and physical validation.",
    "For SD-backed physical replay, use the all-slot SD schedule CSVs, not the SEND-only compact traces."
  ],
  "sd_outputs": {
    "txa": {
      "sd_schedule_path": "traces/run029_sd_txa_schedule.csv",
      "expected_rows": 64,
      "expected_send_rows": 64,
      "expected_skip_rows": 0
    },
    "txb": {
      "sd_schedule_path": "traces/run029_sd_txb_schedule.csv",
      "expected_rows": 64,
      "expected_send_rows": 32,
      "expected_skip_rows": 32
    }
  }
}
